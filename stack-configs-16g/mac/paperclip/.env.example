# ============================================
# PAPERCLIP — Variables d'environnement
# Copier en .env et remplir les valeurs
# ============================================

# PostgreSQL (interne Paperclip)
POSTGRES_PASSWORD=CHANGE_ME

# Auth secret (openssl rand -base64 32)
BETTER_AUTH_SECRET=CHANGE_ME

# n8n webhook key (partage avec le serveur n8n)
N8N_AGENT_KEY=CHANGE_ME

# SiYuan access token
SIYUAN_TOKEN=CHANGE_ME
